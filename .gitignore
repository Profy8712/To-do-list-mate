# .gitignore for Django To-Do List Mate project

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Django stuff
*.log
*.pot
*.pyc
db.sqlite3
media/

# Environments
.env
.venv/
env/
venv/
ENV/
env.bak/
venv.bak/

# IDE specific files
.idea/
.vscode/
*.swp
*.swo

# Static files collected during deployment
staticfiles/

# macOS
.DS_Store

# Database migrations (uncomment if you want to ignore migrations)
# migrations/

# Testing
.coverage
htmlcov/
.pytest_cache/

# PyCharm
.idea/
*.iml

# Virtual environment
venv/